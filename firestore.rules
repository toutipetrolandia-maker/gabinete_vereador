rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(roles) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }

    match /users/{userId} {
      // User can read/write their own profile and team (Requested)
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // Admin/Vereador can see the user list for management (Needed for Settings)
      allow read: if hasRole(['admin', 'vereador']);
      
      // Admin can manage roles
      allow write: if hasRole(['admin']);

      match /team/{teamId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /atendimentos/{id} {
      allow read: if isSignedIn();
      allow write: if hasRole(['admin', 'atendente', 'vereador']);
    }

    match /atendimentos_medicos/{id} {
      allow read: if isSignedIn();
      allow write: if hasRole(['admin', 'atendente', 'vereador']);
    }

    match /malotes/{id} {
      allow read: if isSignedIn();
      allow write: if hasRole(['admin', 'atendente']);
    }

    match /demandas_parlamentares/{id} {
      allow read: if isSignedIn();
      allow write: if hasRole(['admin', 'atendente', 'vereador']);
    }

    match /sugestoes/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); 
    }

    match /logs/{id} {
      allow read: if hasRole(['admin', 'vereador']);
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /app_settings/{id} {
      allow read: if isSignedIn();
      allow write: if hasRole(['admin']);
    }
  }
}
