rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /_connection_test/{id} {
      allow read: if true;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(roles) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none') in roles;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'cleciotecnologia@gmail.com' && request.auth.token.email_verified == true;
    }

    match /users/{userId} {
      // O próprio usuário pode ler seu perfil e equipe, admins podem ler tudo
      allow read: if isSignedIn() && (request.auth.uid == userId || hasRole(['admin', 'vereador']));
      
      // Criação: Próprio usuário (cadastro novo) ou Admin
      allow create: if isSignedIn() && (
        (request.auth.uid == userId && request.resource.data.role == 'consulta' && request.resource.data.ativo == false) ||
        hasRole(['admin'])
      );

      // Apenas Admin pode alterar status ativo ou trocar roles. Próprio usuário pode editar dados básicos.
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'ativo'])) ||
        hasRole(['admin'])
      );
      
      allow delete: if hasRole(['admin']);

      match /team/{teamId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /atendimentos/{id} {
      allow read: if isSignedIn();
      allow write: if hasRole(['admin', 'atendente', 'vereador']);
    }

    match /atendimentos_medicos/{id} {
      allow read: if isSignedIn();
      allow write: if hasRole(['admin', 'atendente', 'vereador']);
    }

    match /malotes/{id} {
      allow read: if isSignedIn();
      allow write: if hasRole(['admin', 'atendente']);
    }

    match /demandas_parlamentares/{id} {
      allow read: if isSignedIn();
      allow write: if hasRole(['admin', 'atendente', 'vereador']);
    }

    match /sugestoes/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); 
    }

    match /logs/{id} {
      allow read: if hasRole(['admin', 'vereador']);
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /app_settings/{id} {
      allow read: if true;
      allow create: if isSuperAdmin() || (
        hasRole(['admin']) && 
        !request.resource.data.keys().hasAny(['system_locked', 'billing_status'])
      );
      allow update: if isSuperAdmin() || (
        hasRole(['admin']) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['system_locked', 'billing_status'])
      );
    }
  }
}
